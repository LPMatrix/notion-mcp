# Notion: create an integration at https://www.notion.so/my-integrations
# Share your database (or parent page) with the integration.
NOTION_TOKEN=
NOTION_DATABASE_ID=
# If you want the script to create a new DB under a page, set this and leave NOTION_DATABASE_ID empty.
NOTION_PAGE_ID=

# OpenRouter: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional: model for research and fact-check (default: anthropic/claude-sonnet-4)
OPENROUTER_MODEL=anthropic/claude-sonnet-4
