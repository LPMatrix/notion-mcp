# OpenRouter: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional: model for research and fact-check
OPENROUTER_MODEL=google/gemini-1.5-flash

# Tavily Search API (required). Get key at https://tavily.com
TAVILY_API_KEY=

# Notion MCP sync (sync_to_notion.py). Uses Python MCP SDK → https://mcp.notion.com/mcp
# NOTION_MCP_ACCESS_TOKEN: OAuth access token (see https://developers.notion.com/guides/mcp/build-mcp-client)
# NOTION_PARENT_PAGE_ID: page ID where the Research claims database will be created
NOTION_MCP_ACCESS_TOKEN=
NOTION_PARENT_PAGE_ID=
